rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function isValidTransaction(data) {
      return data.keys().hasAll(['date', 'item', 'cost', 'type', 'status', 'category', 'mop']) &&
             data.date is string && data.date.size() <= 64 &&
             data.item is string && data.item.size() <= 256 &&
             data.cost is number &&
             data.type is string && data.type.size() <= 64 &&
             data.status is string && data.status.size() <= 64 &&
             data.category is string && data.category.size() <= 64 &&
             data.mop is string && data.mop.size() <= 64;
    }

    function isValidTask(data) {
      return data.keys().hasAll(['title', 'completed', 'createdAt']) &&
             data.title is string && data.title.size() <= 256 &&
             data.completed is bool &&
             data.createdAt is number;
    }

    match /users/{userId} {
      match /transactions/{transactionId} {
        allow read, write: if userId == 'public_sync';
        allow read: if isOwner(userId);
        allow create: if isOwner(userId) && isValidId(transactionId) && isValidTransaction(incoming());
        allow update: if isOwner(userId) && isValidId(transactionId) && isValidTransaction(incoming());
        allow delete: if isOwner(userId) && isValidId(transactionId);
      }

      match /tasks/{taskId} {
        allow read, write: if userId == 'public_sync';
        allow read: if isOwner(userId);
        allow create: if isOwner(userId) && isValidId(taskId) && isValidTask(incoming());
        allow update: if isOwner(userId) && isValidId(taskId) && isValidTask(incoming());
        allow delete: if isOwner(userId) && isValidId(taskId);
      }
    }
  }
}
